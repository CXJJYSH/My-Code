# 灵神的写法 
# 这写法太阴了，TMD，自己想哪里想得到这种方法。 

class Solution:
    def perfectPairs(self, nums: List[int]) -> int:
        nums.sort(key=abs)
        ans = 0
        left = 0

        for j, b in enumerate(nums):
            # 前面一段一直满足前>=后，不进while循环，ans直接加。 
            while abs(nums[left]) * 2 < abs(b):
                left += 1
            ans += j - left 

        return ans 
    
# 时间复杂度O(n log n)，排序。  
# 空间复杂度O(1) 
    
